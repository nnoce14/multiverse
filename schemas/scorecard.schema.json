{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://multiverse.local/schemas/scorecard.schema.json",
  "title": "Iteration Scorecard",
  "type": "object",
  "additionalProperties": false,
  "required": ["iteration_id", "plan_type", "scored_by", "scored_at", "dimensions", "critical_risks", "evidence_debt", "decision_debt", "confidence", "summary"],
  "properties": {
    "iteration_id": { "type": "string", "pattern": "^iteration-\\d{4}$" },
    "plan_type": {
      "type": "string",
      "enum": ["core-plan", "adversarial-counterplan", "core-revision", "leadership-review"]
    },
    "scored_by": { "type": "string", "minLength": 1 },
    "scored_at": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "dimensions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "business_truth_alignment",
        "architecture_boundary_integrity",
        "provider_contract_stability",
        "refusal_safety",
        "developer_workflow_fit",
        "testability_and_tdd_readiness",
        "implementation_sequence",
        "maintenance_cost",
        "release_surface_control",
        "evidence_discipline"
      ],
      "properties": {
        "business_truth_alignment": { "$ref": "#/$defs/scoreDimension" },
        "architecture_boundary_integrity": { "$ref": "#/$defs/scoreDimension" },
        "provider_contract_stability": { "$ref": "#/$defs/scoreDimension" },
        "refusal_safety": { "$ref": "#/$defs/scoreDimension" },
        "developer_workflow_fit": { "$ref": "#/$defs/scoreDimension" },
        "testability_and_tdd_readiness": { "$ref": "#/$defs/scoreDimension" },
        "implementation_sequence": { "$ref": "#/$defs/scoreDimension" },
        "maintenance_cost": { "$ref": "#/$defs/scoreDimension" },
        "release_surface_control": { "$ref": "#/$defs/scoreDimension" },
        "evidence_discipline": { "$ref": "#/$defs/scoreDimension" }
      }
    },
    "critical_risks": {
      "type": "array",
      "items": { "$ref": "#/$defs/risk" }
    },
    "evidence_debt": {
      "type": "array",
      "items": { "$ref": "#/$defs/debt" }
    },
    "decision_debt": {
      "type": "array",
      "items": { "$ref": "#/$defs/debt" }
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "summary": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "scoreDimension": {
      "type": "object",
      "additionalProperties": false,
      "required": ["score", "rationale"],
      "properties": {
        "score": { "type": "number", "minimum": 0, "maximum": 5 },
        "rationale": { "type": "string", "minLength": 1 }
      }
    },
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "severity", "summary", "owner", "status"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "severity": { "type": "string", "enum": ["critical", "high", "medium", "low"] },
        "summary": { "type": "string", "minLength": 1 },
        "owner": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "enum": ["open", "mitigated", "accepted", "deferred"] }
      }
    },
    "debt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "summary", "owner", "status"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "owner": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "enum": ["open", "resolved", "deferred"] }
      }
    }
  }
}
