{
  "resources": [
    {
      "name": "app-db",
      "provider": "path-scoped",
      "isolationStrategy": "path-scoped",
      "scopedValidate": false,
      "scopedReset": true,
      "scopedCleanup": true,
      "appEnv": "DATABASE_PATH"
    },
    {
      "name": "cache-sidecar",
      "provider": "process-port-scoped",
      "isolationStrategy": "process-port-scoped",
      "scopedValidate": false,
      "scopedReset": true,
      "scopedCleanup": true,
      "appEnv": "CACHE_ADDR"
    }
  ],
  "endpoints": [
    {
      "name": "http",
      "role": "application-http",
      "provider": "local-port",
      "appEnv": "APP_HTTP_URL"
    }
  ]
}
